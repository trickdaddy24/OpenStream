# OpenStream Configuration
# Copy this file to .env and fill in values

# TMDB API key (get one at https://www.themoviedb.org/settings/api)
OPENSTREAM_TMDB_API_KEY=your_tmdb_api_key_here

# Secret key for session signing (change this!)
OPENSTREAM_SECRET_KEY=change-me-to-a-random-string

# Server
OPENSTREAM_HOST=0.0.0.0
OPENSTREAM_PORT=8000
OPENSTREAM_DEBUG=true

# FFmpeg (if not on PATH, set full paths)
OPENSTREAM_FFMPEG_PATH=ffmpeg
OPENSTREAM_FFPROBE_PATH=ffprobe

# Max concurrent transcode sessions
OPENSTREAM_MAX_TRANSCODE_SESSIONS=3

# Logging
OPENSTREAM_LOG_MAX_BYTES=5242880
OPENSTREAM_LOG_BACKUP_COUNT=3
